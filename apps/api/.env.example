# ---- Banco de dados ----
# Em dev, sobe via `npm run db:up` (docker compose) com estas credenciais.
# Porta 5433 no host p/ não conflitar com um PostgreSQL local na 5432.
DATABASE_URL="postgresql://nossagrana:nossagrana@localhost:5433/nossagrana?schema=public"

# ---- Servidor ----
NODE_ENV=development
HOST=0.0.0.0
PORT=3333
# Origens permitidas para CORS (separadas por vírgula). Use o host do PWA.
CORS_ORIGIN="http://localhost:5173"

# ---- Auth ----
# Segredos longos e aleatórios. Gere com: openssl rand -hex 48
JWT_ACCESS_SECRET="troque-isto-access-secret-bem-longo-e-aleatorio"
JWT_REFRESH_SECRET="troque-isto-refresh-secret-bem-longo-e-aleatorio"
# Duração do access token (curto) e do refresh token (longo).
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS=30

# ---- Convites ----
INVITATION_TTL_DAYS=7
