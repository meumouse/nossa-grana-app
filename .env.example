# URL base da API. Em dev deixe vazio para usar o proxy do Vite (/api -> :3333).
# Em produção, aponte para o host da API, ex.: https://api.nossagrana.app
VITE_API_URL=

# Client ID OAuth do Google (Google Cloud > Credentials > OAuth client ID, tipo
# "Web application"). Mesmo valor do GOOGLE_OAUTH_CLIENT_ID na API. Sem ele o
# botão "Entrar com Google" simplesmente não aparece. Lembre de cadastrar a
# origem do PWA (ex.: http://localhost:5173) em "Authorized JavaScript origins".
VITE_GOOGLE_CLIENT_ID=
